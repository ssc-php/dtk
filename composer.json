{
    "name": "ssc/dtk",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Loïc Faugeron",
            "email": "faugeron.loic@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.5",
        "symfony/console": "^8.0.7",
        "symfony/dotenv": "^8.0.7",
        "symfony/framework-bundle": "^8.0.7",
        "symfony/runtime": "^8.0.1",
        "symfony/yaml": "^8.0.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "phpspec/prophecy-phpunit": "^2.5",
        "phpunit/phpunit": "^13.0.5"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Ssc\\Dtk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ssc\\Dtk\\Tests\\": "tests/"
        }
    }
}
