{
    "name": "ssc/dtk",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Loïc Faugeron",
            "email": "faugeron.loic@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.5",
        "symfony/console": "^8.0.8",
        "symfony/dotenv": "^8.0.8",
        "symfony/framework-bundle": "^8.0.8",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/runtime": "^8.0.8",
        "symfony/yaml": "^8.0.8"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "phpspec/prophecy-phpunit": "^2.5",
        "phpunit/phpunit": "^13.1.1",
        "jangregor/phpstan-prophecy": "^2.3",
        "phpstan/phpstan": "^2.1.46",
        "rector/rector": "^2.4.1",
        "rector/swiss-knife": "^2.3.5"
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-mbstring": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php84": "*",
        "symfony/polyfill-php85": "*"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Ssc\\Dtk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ssc\\Dtk\\Dev\\": "dev/",
            "Ssc\\Dtk\\Tests\\": "tests/"
        }
    }
}
